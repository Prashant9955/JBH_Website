PORT=5001
NODE_ENV=development

# In dev, allow the Vite frontend origin
FRONTEND_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/jbh_hostel

# Change in production
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Cookie settings (dev defaults)
COOKIE_NAME=jbh_token
